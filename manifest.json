{
  "manifest_version": 3,
  "name": "ScreenSnap",
  "version": "1.0.0",
  "description": "Screen recorder - full screen with audio, runs in background",
  "permissions": [
    "tabCapture",
    "desktopCapture",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}